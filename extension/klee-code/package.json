{
  "name": "klee-code",
  "displayName": "Klee Code",
  "description": "On-prem coding assistant",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.125.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onView:klee-code.chatView",
    "onCommand:klee-code.askAssistant",
    "onCommand:klee-code.newConversation"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "panel": [
        {
          "id": "klee-code",
          "title": "Klee Code",
          "icon": "resources/klee-code.svg"
        }
      ]
    },
    "views": {
      "klee-code": [
        {
          "id": "klee-code.chatView",
          "name": "Chat",
          "type": "webview",
          "icon": "resources/klee-code.svg"
        }
      ]
    },
    "commands": [
      {
        "command": "klee-code.askAssistant",
        "title": "Klee Code: Ask Assistant"
      },
      {
        "command": "klee-code.newConversation",
        "title": "Klee Code: New Conversation"
      }
    ],
    "configuration": {
      "title": "Klee Code",
      "properties": {
        "klee-code.backendUrl": {
          "type": "string",
          "default": "http://localhost:8080",
          "description": "Klee Code backend server URL"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.125.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "esbuild": "^0.27.3",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
