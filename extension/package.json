{
  "name": "klee-code",
  "displayName": "Klee Code",
  "description": "On-prem coding assistant",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0",
    "vscode": "^1.125.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onView:klee-code.chatView",
    "onCommand:klee-code.askAssistant",
    "onCommand:klee-code.newConversation"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "panel": [
        {
          "id": "klee-code",
          "title": "Klee Code",
          "icon": "resources/klee-code.svg"
        }
      ]
    },
    "views": {
      "klee-code": [
        {
          "id": "klee-code.chatView",
          "name": "Chat",
          "type": "webview",
          "icon": "resources/klee-code.svg"
        }
      ]
    },
    "commands": [
      {
        "command": "klee-code.askAssistant",
        "title": "Klee Code: Ask Assistant"
      },
      {
        "command": "klee-code.newConversation",
        "title": "Klee Code: New Conversation"
      }
    ],
    "configuration": {
      "title": "Klee Code",
      "properties": {
        "klee-code.backendUrl": {
          "type": "string",
          "default": "http://localhost:8080",
          "description": "Klee Code backend server URL"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && npm run build",
    "build": "npm run build:extension && npm run build:webview",
    "build:extension": "vite build --config vite.extension.config.ts --mode development",
    "build:webview": "vite build --config vite.webview.config.ts --mode development",
    "build:extension:prod": "vite build --config vite.extension.config.ts --mode production",
    "build:webview:prod": "vite build --config vite.webview.config.ts --mode production",
    "watch": "npm-run-all -p watch:*",
    "watch:vite:extension": "vite build --config vite.extension.config.ts --mode development --watch",
    "watch:vite:webview": "vite build --config vite.webview.config.ts --mode development --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && npm run build:extension:prod && npm run build:webview:prod",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit && tsc --noEmit --project webview-ui/tsconfig.json",
    "lint": "oxlint src webview-ui/src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/vscode": "^1.125.0",
    "@vitejs/plugin-react": "^6.0.2",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "npm-run-all": "^4.1.5",
    "oxlint": "^1.70.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.16"
  },
  "dependencies": {
    "highlight.js": "^11.11.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  }
}
